{
  "info": {
    "name": "BotBlocker - Backend Engineering Assignment",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Complete API collection for the BotBlocker Spring Boot microservice. Tests all phases: Core API, Redis Guardrails, and the Notification Engine.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "post_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "bot_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Setup - Create User",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"alice\",\n  \"isPremium\": false\n}"
        }
      }
    },
    {
      "name": "Setup - Create Bot",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/bots", "host": ["{{base_url}}"], "path": ["api", "bots"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"GPT-Bot-Alpha\",\n  \"personaDescription\": \"A friendly AI assistant bot.\"\n}"
        }
      }
    },
    {
      "name": "Phase 1 - Create Post",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/posts", "host": ["{{base_url}}"], "path": ["api", "posts"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": {{user_id}},\n  \"authorType\": \"USER\",\n  \"content\": \"Hello world! This is my first post.\"\n}"
        }
      }
    },
    {
      "name": "Phase 1 - Add Human Comment",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/posts/{{post_id}}/comments", "host": ["{{base_url}}"], "path": ["api", "posts", "{{post_id}}", "comments"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": {{user_id}},\n  \"authorType\": \"USER\",\n  \"content\": \"Great post!\",\n  \"parentCommentId\": null\n}"
        }
      }
    },
    {
      "name": "Phase 1 - Add Bot Comment (Top-Level)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/posts/{{post_id}}/comments", "host": ["{{base_url}}"], "path": ["api", "posts", "{{post_id}}", "comments"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": {{bot_id}},\n  \"authorType\": \"BOT\",\n  \"content\": \"Hello! I am GPT-Bot-Alpha replying to your post.\",\n  \"parentCommentId\": null\n}"
        }
      }
    },
    {
      "name": "Phase 1 - Like Post (Human)",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/posts/{{post_id}}/like?authorType=USER",
          "host": ["{{base_url}}"],
          "path": ["api", "posts", "{{post_id}}", "like"],
          "query": [{ "key": "authorType", "value": "USER" }]
        }
      }
    },
    {
      "name": "Phase 2 - Get Virality Score",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/api/posts/{{post_id}}/virality", "host": ["{{base_url}}"], "path": ["api", "posts", "{{post_id}}", "virality"] }
      }
    },
    {
      "name": "Phase 2 - Test Cooldown Cap (2nd Bot Comment - should be blocked)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/posts/{{post_id}}/comments", "host": ["{{base_url}}"], "path": ["api", "posts", "{{post_id}}", "comments"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": {{bot_id}},\n  \"authorType\": \"BOT\",\n  \"content\": \"Trying to comment again within 10 minutes - this should fail.\",\n  \"parentCommentId\": null\n}"
        }
      }
    },
    {
      "name": "Phase 2 - Test Vertical Cap (depth 21 - should be blocked)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/posts/{{post_id}}/comments", "host": ["{{base_url}}"], "path": ["api", "posts", "{{post_id}}", "comments"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 2,\n  \"authorType\": \"BOT\",\n  \"content\": \"Deeply nested comment that should fail if depth > 20.\",\n  \"parentCommentId\": 1\n}"
        }
      }
    },
    {
      "name": "Phase 3 - Bot Comment (triggers notification check)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/posts/{{post_id}}/comments", "host": ["{{base_url}}"], "path": ["api", "posts", "{{post_id}}", "comments"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 2,\n  \"authorType\": \"BOT\",\n  \"content\": \"Bot-2 sending a notification test reply!\",\n  \"parentCommentId\": null\n}"
        }
      }
    },
    {
      "name": "Phase 4 - Verify Bot Count (race condition test)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/api/posts/{{post_id}}/virality", "host": ["{{base_url}}"], "path": ["api", "posts", "{{post_id}}", "virality"] }
      }
    },
    {
      "name": "Phase 4 - 404 on missing post",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/posts/99999/like?authorType=USER", "host": ["{{base_url}}"], "path": ["api", "posts", "99999", "like"], "query": [{ "key": "authorType", "value": "USER" }] }
      }
    },
    {
      "name": "Phase 4 - Invalid authorType (should return 400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/posts/{{post_id}}/like?authorType=INVALID", "host": ["{{base_url}}"], "path": ["api", "posts", "{{post_id}}", "like"], "query": [{ "key": "authorType", "value": "INVALID" }] }
      }
    }
  ]
}
